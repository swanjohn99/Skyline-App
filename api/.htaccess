# Route every /api/* request to the front controller.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /api/

  # Serve uploaded files directly.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.php [L]
</IfModule>

# Never serve sensitive files directly.
<FilesMatch "\.(env|sql)$">
  Require all denied
</FilesMatch>

<Files "config.php">
  Require all denied
</Files>
