# Copy to api/.env and fill in. Never commit api/.env.

# ── Database (MariaDB / MySQL) ──
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="skyline"
DB_USER="skyline_user"
DB_PASS="change-me"

# ── App ──
# Public base URL of the SPA (used to build password-reset links).
APP_URL="https://skylineconstructions.in/app"
APP_ENV="production"

# ── Mail (password reset) ──
# Leave SMTP_HOST empty to fall back to PHP mail().
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="tls"   # tls | ssl | none
MAIL_FROM="no-reply@skylineconstructions.in"
MAIL_FROM_NAME="Skyline Constructions"
